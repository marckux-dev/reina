---
interface Crumb {
  name: string;
  href?: string;
}
interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;
---
<nav aria-label="Ruta de navegación" class="container mx-auto px-6 pt-4 pb-1">
  <div class="breadcrumbs text-sm text-base-content/60">
    <ul>
      {crumbs.map((crumb, i) => (
        <li>
          {i < crumbs.length - 1
            ? <a href={crumb.href} class="hover:text-primary transition-colors">{crumb.name}</a>
            : <span class="text-base-content/90">{crumb.name}</span>
          }
        </li>
      ))}
    </ul>
  </div>
</nav>
