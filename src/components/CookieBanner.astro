---
import { useTranslations, defaultLang, type Language } from '../i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Language;
const t = useTranslations(lang);
const cookiePolicyUrl = '/legal/politica-cookies';
---

<div
  id="cookie-banner"
  class="fixed bottom-4 left-1/2 -translate-x-1/2 max-w-3xl w-[95%] flex flex-col md:flex-row
  items-start md:items-center gap-4 bg-base-100 border border-base-300 rounded-l-2xl
  shadow-xl p-6 text-sm z-50"
  hidden
>
  <p class="flex-1 text-base-content leading-relaxed">
    {t('cookie.text')}
    <a href={cookiePolicyUrl} class="link link-primary ml-1">{t('cookie.moreInfo')}</a>
  </p>
  <div class="flex gap-2 shrink-0">
    <button id="cookie-reject" class="btn btn-outline btn-sm">{t('cookie.reject')}</button>
    <button id="cookie-accept" class="btn btn-primary btn-sm">{t('cookie.accept')}</button>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('cookie-accept');
  const rejectBtn = document.getElementById('cookie-reject');
  const CONSENT_KEY = 'cookie-consent';
  const hasGACookies = () => document.cookie.split(';').some(c => c.trim().startsWith('_ga'));

  const consent = localStorage.getItem(CONSENT_KEY);

  if (!consent && !!banner) {
    banner.hidden = false;
  }

  if (consent === 'accepted' && !hasGACookies()) {
    localStorage.removeItem(CONSENT_KEY);
    if (!!banner) banner.hidden = false;
  }

  if (consent === 'accepted' && hasGACookies()) {
    import('../scripts/load-ga.js').then(m => m.loadGoogleAnalytics());
  }

  acceptBtn?.addEventListener('click', async () => {
    localStorage.setItem(CONSENT_KEY, 'accepted');
    const { loadGoogleAnalytics } = await import('../scripts/load-ga.js');
    loadGoogleAnalytics();
    if (!!banner) banner.hidden = true;
  });

  rejectBtn?.addEventListener('click', () => {
    localStorage.setItem(CONSENT_KEY, 'rejected');
    if (!!banner) banner.hidden = true;
  });
</script>
