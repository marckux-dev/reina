---
import MainLayout from "../../layouts/MainLayout.astro";
import Card from "../../components/Card.astro";
import ContactButton from "../../components/ContactButton.astro";
import { getCollection } from 'astro:content';
const services = (await getCollection('services'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<MainLayout 
  title="Servicios de Limpieza Industrial y Tratamiento de Suelos"
  description="Servicios de limpieza industrial, pulido de suelos y tratamientos de superficies en Alicante y Costa Blanca. Empresas, hoteles, comunidades y particulares. Presupuesto gratuito."
>
  <main class="container mx-auto my-8">
    <h1 class="text-3xl font-bold text-center mt-4 mb-4">
      Nuestros Servicios
    </h1>

    <div class="grid
      grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6
      gap-4"
    >
      {
      services.map( service => (
      <Card
        image={ service.data.headerImage }
        title={ service.data.navItem }
        href={ `/servicios/${ service.slug }` }
      />
      ))
      }
    </div>

    <div class="flex justify-center my-8">
      <ContactButton link="/contacto" text="Pide presupuesto" />
    </div>
  </main>
</MainLayout>
