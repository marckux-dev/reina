---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import MainLayout from '../../../layouts/MainLayout.astro';

export const getStaticPaths = (() => [
  { params: { lang: 'en' } },
  { params: { lang: 'ru' } },
]) satisfies GetStaticPaths;

const { lang } = Astro.params;

const t = {
  en: {
    metaTitle: 'Our Work — Cleaning & Treatments on the Costa Blanca',
    metaDesc: 'Real examples of industrial cleaning, floor polishing and surface treatment projects carried out by Reina Multiservicios at hotels and businesses on the Costa Blanca.',
    h1: 'Our Work',
    desc: 'Real examples of our services at hotels, communities, private homes and businesses in Alicante and the Costa Blanca.',
    locale: 'en-GB',
  },
  ru: {
    metaTitle: 'Наши работы — Уборка и обработка на Коста-Бланке',
    metaDesc: 'Реальные примеры проектов промышленной уборки, полировки полов и обработки поверхностей, выполненных Reina Multiservicios в отелях и компаниях Коста-Бланки.',
    h1: 'Наши работы',
    desc: 'Реальные примеры наших услуг в отелях, ТСЖ, частных домах и компаниях Аликанте и Коста-Бланки.',
    locale: 'ru-RU',
  },
}[lang];

const collectionName = lang === 'ru' ? 'trabajos-ru' : 'trabajos-en';
const trabajos = (await getCollection(collectionName))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const imagesMap = import.meta.glob<ImageMetadata>('../../../assets/images/**/*.{png,jpg,jpeg,webp,avif}', {
  eager: true,
  import: 'default',
});
---

<MainLayout title={t.metaTitle} description={t.metaDesc}>
  <main>
    <header class="bg-base-200 py-16 px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">{t.h1}</h1>
      <p class="text-lg md:text-xl text-base-content/70 max-w-2xl mx-auto">{t.desc}</p>
    </header>

    <section class="container mx-auto px-6 py-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {trabajos.map(trabajo => {
        const normalizedSrc = trabajo.data.coverImage.src.startsWith('/') ? trabajo.data.coverImage.src.slice(1) : trabajo.data.coverImage.src;
        const coverAsset = imagesMap[`../../../assets/images/${normalizedSrc}`];
        return (
          <a href={`/${lang}/trabajos/${trabajo.slug}/`} class="card bg-base-100 shadow-md hover:shadow-lg transition-shadow duration-300 overflow-hidden group">
            {coverAsset && (
              <figure class="overflow-hidden h-52">
                <Image
                  src={coverAsset}
                  alt={trabajo.data.coverImage.alt}
                  widths={[400, 600]}
                  sizes="(max-width: 768px) 100vw, 33vw"
                  quality={65}
                  format="webp"
                  loading="lazy"
                  data-fade
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </figure>
            )}
            <div class="card-body">
              <div class="flex flex-wrap gap-2 mb-2">
                <span class="badge badge-primary badge-sm">{trabajo.data.city}</span>
                <span class="badge badge-outline badge-sm">{trabajo.data.serviceLabel}</span>
              </div>
              <h2 class="card-title text-base leading-snug">{trabajo.data.h1}</h2>
              <p class="text-sm text-base-content/60 mt-1">
                {trabajo.data.date.toLocaleDateString(t.locale, { year: 'numeric', month: 'long' })}
              </p>
            </div>
          </a>
        );
      })}
    </section>
  </main>
</MainLayout>
