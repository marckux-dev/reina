---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import type { ImageMetadata } from 'astro';
import MainLayout from '../../../layouts/MainLayout.astro';
import HeroService from '../../../components/HeroService.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import Gallery from '../../../components/Gallery.astro';
import InstagramReel from '../../../components/InstagramReel.astro';

export const getStaticPaths = (async () => {
  const [trabajosEn, trabajosRu] = await Promise.all([
    getCollection('trabajos-en'),
    getCollection('trabajos-ru'),
  ]);
  return [
    ...trabajosEn.map(entry => ({ params: { lang: 'en', slug: entry.slug }, props: { entry } })),
    ...trabajosRu.map(entry => ({ params: { lang: 'ru', slug: entry.slug }, props: { entry } })),
  ];
}) satisfies GetStaticPaths;

const { lang } = Astro.params;
const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;

const t = {
  en: {
    home: 'Home', works: 'Works',
    ctaTitle: (city: string) => `Do you need this service in ${city} or nearby?`,
    ctaDesc: 'We carry out technical visits with no commitment. Tell us about your project and we will send you a quote.',
    ctaQuote: 'Request a quote',
    ctaService: 'See service:',
  },
  ru: {
    home: 'Главная', works: 'Работы',
    ctaTitle: (city: string) => `Нужна эта услуга в ${city} или поблизости?`,
    ctaDesc: 'Проводим технические визиты без обязательств. Расскажите о своём проекте — пришлём смету.',
    ctaQuote: 'Запросить смету',
    ctaService: 'Смотреть услугу:',
  },
}[lang];

const allImages = import.meta.glob<ImageMetadata>('../../../assets/images/**/*.{png,jpg,jpeg,webp,avif}', { eager: true, import: 'default' });
function resolveImg(src: string): ImageMetadata | undefined {
  const normalized = src.startsWith('/') ? src.slice(1) : src;
  return allImages[`../../../assets/images/${normalized}`];
}
const coverImageMeta = resolveImg(data.coverImage.src);
const galleryMeta = (data.gallery ?? []).map(img => ({
  ...img,
  src: resolveImg(img.src) ?? img.src,
}));
---

<MainLayout title={data.title} description={data.description} ogImage={coverImageMeta?.src}>
  <main>
    <HeroService
      title={data.h1}
      subtitle={data.location ? `${data.location} · ${data.city}` : data.city}
      image={coverImageMeta ?? data.coverImage.src}
    />

    <Breadcrumb crumbs={[
      { name: t.home, href: `/${lang}/` },
      { name: t.works, href: `/${lang}/trabajos/` },
      { name: data.h1 },
    ]} />

    <section class="service-content trabajo-content"><Content /></section>

    {data.videoUrl && <InstagramReel url={data.videoUrl} />}
    {galleryMeta.length > 0 && <Gallery images={galleryMeta} serviceTitle={data.h1} />}

    <section class="bg-base-200 py-14 px-6 text-center mb-4">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">{t.ctaTitle(data.city)}</h2>
      <p class="text-base-content/70 mb-8 max-w-xl mx-auto">{t.ctaDesc}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`/${lang}/contacto/`} class="btn btn-primary">{t.ctaQuote}</a>
        <a href={`/${lang}/servicios/${data.service}/`} class="btn btn-outline">
          {t.ctaService} {data.serviceLabel}
        </a>
      </div>
    </section>
  </main>
</MainLayout>
