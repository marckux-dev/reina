---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import { siteMap, getLocalizedSiteMap } from '../data/siteMap';
import { defaultLang, type Language, useTranslations } from '../i18n/ui';
import LocalSEO from '../components/LocalSEO.astro';
interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  ogImage?: string;
}
const { title, description, noindex = false, ogImage } = Astro.props;

const currentLang = (Astro.currentLocale ?? defaultLang) as Language;
const localizedSiteMap = getLocalizedSiteMap(currentLang);
const t = useTranslations(currentLang);

const siteUrl = 'https://reinamultiservicios.es';
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const fullTitle = title.includes('| Reina Multiservicios') ? title : `${title} | Reina Multiservicios`;

const basePath = Astro.url.pathname.replace(/^\/(en|ru)(?=\/|$)/, '') || '/';
const hreflangEs = `${siteUrl}${basePath}`;
const hreflangEn = `${siteUrl}/en${basePath}`;
const hreflangRu = `${siteUrl}/ru${basePath}`;
const ogImageUrl = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}/og-image.webp`;
const metaDescription = description ?? 'Empresa de limpieza industrial, pulidos y tratamientos de superficies en Alicante y Costa Blanca. Más de 30 años de experiencia. Presupuesto gratuito.';

---

<html lang={currentLang}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/FaviconReina.svg" />
    <link rel="canonical" href={canonicalUrl}>
    <link rel="alternate" hreflang="es" href={hreflangEs} />
    <link rel="alternate" hreflang="en" href={hreflangEn} />
    <link rel="alternate" hreflang="ru" href={hreflangRu} />
    <link rel="alternate" hreflang="x-default" href={hreflangEs} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    {
      noindex? (
        <meta name="robots" content="noindex, nofollow" />
      ):(
        <meta name="robots" content="index, follow" />
      )
    }
    <meta name="description" content={metaDescription} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Reina Multiservicios" />
    <meta property="og:locale" content={currentLang === 'en' ? 'en_GB' : currentLang === 'ru' ? 'ru_RU' : 'es_ES'} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={t('og.imageAlt')} />
    <meta property="og:locale:alternate" content={currentLang === 'es' ? 'en_GB' : 'es_ES'} />
    <meta property="og:locale:alternate" content={currentLang === 'ru' ? 'en_GB' : 'ru_RU'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <LocalSEO />
    <script>
      document.addEventListener('DOMContentLoaded', ()=>{
        document.querySelectorAll('img[data-fade]').forEach(img => {
          if (img.complete) {
            img.classList.add('is-loaded');
          } else {
            img.addEventListener('load', () => {
              img.classList.add('is-loaded');
            });
          }
        });
      });
    </script>
	</head>
  
  <!-- Google tag (gtag.js) -->


  <!-- Fin del Head. Inicio del body -->

	<body>
    <Navbar siteMap={localizedSiteMap} />
    <slot />
    <Footer />
  <CookieBanner />
	</body>
</html>
