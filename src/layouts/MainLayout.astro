---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import { siteMap } from '../data/siteMap';
import { company } from '../data/company';
interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  ogImage?: string;
}
const { title, description, noindex = false, ogImage } = Astro.props;

const siteUrl = 'https://reinamultiservicios.es';
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const fullTitle = `${title} | Reina Multiservicios`;
const ogImageUrl = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}/og-image.webp`;
const metaDescription = description ?? 'Empresa de limpieza industrial, pulidos y tratamientos de superficies en Alicante y Costa Blanca. Más de 30 años de experiencia. Presupuesto gratuito.';

---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/FaviconReina.svg" />
    <link rel="canonical" href={canonicalUrl}>
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    {
      noindex? (
        <meta name="robots" content="noindex, nofollow" />
      ):(
        <meta name="robots" content="index, follow" />
      )
    }
    <meta name="description" content={metaDescription} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Reina Multiservicios" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Reina Multiservicios — Limpieza industrial y tratamientos de suelos en Alicante" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <script 
      type="application/ld+json"
      set:html={ JSON.stringify({
          "@context": "https://schema.org",
          "@type": ["LocalBusiness", "CleaningService"],
          "@id": "https://reinamultiservicios.es/#localbusiness",
          "name": company.name,
          "foundingDate": "2017",
          "legalName": `${company.name} S.L.`,
          "url": "https://reinamultiservicios.es",
          "telephone": company.phoneList[0].phoneLink.replace('tel:', ''),
          "email": company.mails[0],
          "address": {
            "@type": "PostalAddress",
            "streetAddress": company.address,
            "addressLocality": "La Nucia",
            "addressRegion": "Alicante",
            "postalCode": "03530",
            "addressCountry": "ES"
          },
          "geo": {
            "@type": "GeoCoordinates",
            "latitude": 38.60037,
            "longitude": -0.13152
          },
          "areaServed": [
            {
              "@type": "Country",
              "name": "España"
            },
            {
              "@type": "AdministrativeArea",
              "name": "Comunitat Valenciana"
            },
            {
              "@type": "AdministrativeArea",
              "name": "Alicante"
            },
            {
              "@type": "Place",
              "name": "Benidorm",
            },
            {
              "@type": "Place",
              "name": "Calp"
            },
            {
              "@type": "Place",
              "name": "La Vila Joiosa"
            },
            {
              "@type": "Place",
              "name": "Altea"
            }
          ],
          "priceRange": "€€",
          "hasMap": "https://maps.app.goo.gl/gBPjTHSERKmAVCoK7",
          "sameAs": [
            "https://maps.app.goo.gl/gBPjTHSERKmAVCoK7"
          ]
      })} 
    />
    <script>
      document.addEventListener('DOMContentLoaded', ()=>{
        document.querySelectorAll('img[data-fade]').forEach(img => {
          if (img.complete) {
            img.classList.add('is-loaded');
          } else {
            img.addEventListener('load', () => {
              img.classList.add('is-loaded');
            });
          }
        });
      });
    </script>
	</head>
  
  <!-- Google tag (gtag.js) -->


  <!-- Fin del Head. Inicio del body -->

	<body>
    <Navbar siteMap={ siteMap } />
    <slot />
    <Footer />
  <CookieBanner />
	</body>
</html>
